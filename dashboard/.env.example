# ─── VPS Monitor — Configuration ─────────────────────────────────────────────
# Copier vers .env et remplir les valeurs avant docker compose up

# ── Authentification dashboard ────────────────────────────────────────────────
DASHBOARD_USER=admin

# Générer le hash bcrypt :
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext "VOTRE_MOT_DE_PASSE"
DASHBOARD_PASS_HASH=$2a$14$REMPLACER_PAR_LE_HASH_GENERE

# ── CrowdSec LAPI (optionnel mais recommandé) ─────────────────────────────────
# Sans clé → fallback sur "docker exec crowdsec cscli" (plus lent)
# Générer la clé :
#   docker exec crowdsec cscli bouncers add vps-dashboard
CROWDSEC_API_KEY=

# ── Noms des containers (à ajuster si différents) ─────────────────────────────
ENDLESSH_CONTAINER=endlessh
CROWDSEC_CONTAINER=crowdsec
